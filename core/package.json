{
  "name": "@website/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client/prisma": {
      "import": "./dist/client/prisma.js",
      "types": "./dist/client/prisma.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./config": {
      "import": "./dist/config/default.js",
      "types": "./dist/config/default.d.ts"
    }
  },
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && tsc",
    "dev": "tsc --watch",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "pino": "^10.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^22.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.3.1",
    "typescript": "^5.7.2"
  }
}
