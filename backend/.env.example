# Option 1: Full connection string
# DATABASE_URL="mongodb://localhost:27017/website?directConnection=true"

# Option 2: Individual vars (DATABASE_URL is built automatically)
# MONGO_HOST=mongodb.railway.internal
# MONGO_PORT=27017
# MONGO_USER=mongo
# MONGO_PASSWORD=your_password
# MONGO_DATABASE=website
# MONGO_AUTH_SOURCE=admin  # optional, if user is in admin db

CLIENT_URL="http://localhost:5173"
PORT=8080
