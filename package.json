{
  "name": "@website/mono",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @website/gems dev\" \"pnpm --filter @website/frontend dev\" --names \"gems,frontend\" --prefix-colors \"cyan,magenta\"",
    "build": "pnpm --filter @website/gems build && pnpm -r build",
    "build:gems": "pnpm --filter @website/gems build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "type-check": "pnpm -r type-check",
    "clean": "rm -rf node_modules && pnpm -r exec rm -rf node_modules dist",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}

